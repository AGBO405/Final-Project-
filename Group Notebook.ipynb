    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load the data\n",
    "crime = pd.read_csv(\"crime.csv\", low_memory=False)\n",
    "housing = pd.read_csv(\"housing.csv\")\n",
    "employment = pd.read_csv(\"employment (1).csv\")\n",
    "\n",
    "# Clean the data\n",
    "crime = crime.dropna(subset=[\"Neighborhood\"])\n",
    "crime_table = crime[\"Neighborhood\"].value_counts().reset_index()\n",
    "crime_table.columns = [\"Neighborhood\", \"Crime Count\"]\n",
    "\n",
    "housing['% Occupied Units (2010)'] = housing['% Occupied Units (2010)'].str.replace('%', '').astype(float)\n",
    "housing['% Vacant Units (2010)'] = housing['% Vacant Units (2010)'].str.replace('%', '').astype(float)\n",
    "housing['% of all Housing Units Foreclosed (2010)'] = housing['% of all Housing Units Foreclosed (2010)'].str.replace('%', '').astype(float)\n",
    "housing['Population (2010)'] = housing['Population (2010)'].str.replace(',', '').astype(float)\n",
    "housing = housing[housing['Population (2010)'] >= 500]\n",
    "housing['Housing Score'] = (\n",
    "    housing['% Occupied Units (2010)'] -\n",
    "    housing['% Vacant Units (2010)'] -\n",
    "    housing['% of all Housing Units Foreclosed (2010)']\n",
    ")\n",
    "\n",
    "employment[\"Population (2010)\"] = employment[\"Population (2010)\"].str.replace(\",\", \"\").astype(float)\n",
    "employment[\"Total Age 16+ N'hood Residents Employed (2010 Est.)\"] = pd.to_numeric(\n",
    "    employment[\"Total Age 16+ N'hood Residents Employed (2010 Est.)\"], errors=\"coerce\"\n",
    ")\n",
    "employment = employment[employment[\"Population (2010)\"] >= 500]\n",
    "employment[\"Employment Score\"] = (\n",
    "    employment[\"Total Age 16+ N'hood Residents Employed (2010 Est.)\"] /\n",
    "    employment[\"Population (2010)\"]\n",
    ")\n",
    "\n",
    "# Normalize\n",
    "def normalize(series):\n",
    "    return (series - series.min()) / (series.max() - series.min())\n",
    "crime_table[\"Crime Score\"] = 1 - normalize(crime_table[\"Crime Count\"])\n",
    "housing[\"Housing Score Norm\"] = normalize(housing[\"Housing Score\"])\n",
    "employment[\"Employment Score Norm\"] = normalize(employment[\"Employment Score\"])\n",
    "\n",
    "# Combine metric into one\n",
    "merged = crime_table[[\"Neighborhood\", \"Crime Score\"]]\n",
    "merged = merged.merge(\n",
    "    housing[[\"Neighborhood\", \"Housing Score Norm\"]],\n",
    "    on=\"Neighborhood\"\n",
    ")\n",
    "merged = merged.merge(\n",
    "    employment[[\"Neighborhood\", \"Employment Score Norm\"]],\n",
    "    on=\"Neighborhood\"\n",
    ")\n",
    "\n",
    "# Final Score\n",
    "merged[\"Final Score\"] = (\n",
    "    merged[\"Crime Score\"] +\n",
    "    merged[\"Housing Score Norm\"] +\n",
    "    merged[\"Employment Score Norm\"]\n",
    ") / 3\n",
    "\n",
    "# Determine best\n",
    "best_overall = merged.sort_values(by=\"Final Score\", ascending=False)\n",
    "print(\"Top 10 Best Neighborhoods in Pittsburgh:\")\n",
    "print(best_overall.head(10))\n",
    "\n",
    "# Visualize\n",
    "top10 = best_overall.head(10)\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.barh(top10[\"Neighborhood\"], top10[\"Final Score\"])\n",
    "plt.xlabel(\"Final Score\")\n",
    "plt.title(\"Top 10 Best Neighborhoods in Pittsburgh\")\n",
    "plt.gca().invert_yaxis()\n",
    "plt.show()"
   ]
